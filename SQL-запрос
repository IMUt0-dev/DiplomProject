REVOKE ALL ON stock FROM role_courier;

-- Настройка Row-Level Security

-- RLS для таблицы Customer - защита персональных данных
ALTER TABLE customer ENABLE ROW LEVEL SECURITY;

-- Политика: приложение видит все строки, но без хэша пароля
CREATE POLICY app_customer_access ON customer
    FOR ALL
    TO role_app
    USING (true)
    WITH CHECK (true);

-- Политика: анонимный пользователь не видит таблицу customer вообще
CREATE POLICY anonymous_customer_deny ON customer
    FOR ALL
    TO role_anonymous
    USING (false);

-- Политика: курьер не видит данные клиентов
CREATE POLICY courier_customer_deny ON customer
    FOR ALL
    TO role_courier
    USING (false);

-- Политика: отдел закупок не видит данные клиентов
CREATE POLICY purchasing_customer_deny ON customer
    FOR ALL
    TO role_purchasing
    USING (false);

-- RLS для таблицы Order - контекстно-зависимый доступ
ALTER TABLE orders ENABLE ROW LEVEL SECURITY;

-- Политика: приложение видит все заказы
CREATE POLICY app_order_access ON orders
    FOR ALL
    TO role_app
    USING (true)
    WITH CHECK (true);

-- Политика: курьер видит только те заказы, которые назначены ему для доставки
-- Идентификатор курьера передаётся через параметр сессии
CREATE POLICY courier_order_access ON orders
    FOR SELECT
    TO role_courier
    USING (
        order_id IN (
            SELECT d.order_id
            FROM delivery d
            WHERE d.courier_name = current_setting('app.courier_name', true)
        )
    );

-- Политика: курьер может обновлять только статус доставки
-- Прямое обновление таблицы Order для курьера запрещено
CREATE POLICY courier_order_update_deny ON orders
    FOR UPDATE
    TO role_courier
    USING (false);

-- Политика: анонимный пользователь не видит заказы
CREATE POLICY anonymous_order_deny ON orders
    FOR ALL
    TO role_anonymous
    USING (false);

-- Политика: отдел закупок не видит заказы
CREATE POLICY purchasing_order_deny ON orders
    FOR ALL
    TO role_purchasing
    USING (false);

-- RLS для таблицы Payment - финансовая информация
ALTER TABLE payment ENABLE ROW LEVEL SECURITY;

-- Политика: только приложение имеет полный доступ к платежам
CREATE POLICY app_payment_access ON payment
    FOR ALL
    TO role_app
    USING (true)
    WITH CHECK (true);

-- Политика: все остальные роли не видят финансовые транзакции
CREATE POLICY deny_payment_access ON payment
    FOR ALL
    TO role_anonymous, role_courier, role_purchasing
    USING (false);

-- RLS для таблицы Delivery - доступ для курьеров
ALTER TABLE delivery ENABLE ROW LEVEL SECURITY;

-- Политика: курьер видит только свои доставки
CREATE POLICY courier_delivery_access ON delivery
    FOR SELECT
    TO role_courier
    USING (
        courier_name = current_setting('app.courier_name', true)
    );

-- Политика: курьер может обновлять только свои доставки
CREATE POLICY courier_delivery_update ON delivery
    FOR UPDATE
    TO role_courier
    USING (
        courier_name = current_setting('app.courier_name', true)
    )
    WITH CHECK (
        courier_name = current_setting('app.courier_name', true)
    );

-- Политика: приложение имеет полный доступ к доставкам
CREATE POLICY app_delivery_access ON delivery
    FOR ALL
    TO role_app
    USING (true)
    WITH CHECK (true);

-- Политика: анонимный пользователь не видит доставки
CREATE POLICY anonymous_delivery_deny ON delivery
    FOR ALL
    TO role_anonymous
    USING (false);

-- Вспомогательная функция для установки контекста курьера
-- Вызывается приложением при аутентификации курьера
CREATE OR REPLACE FUNCTION set_courier_context(courier_login TEXT)
RETURNS TEXT
LANGUAGE plpgsql
SECURITY DEFINER
SET search_path = ''
AS $$
BEGIN
    -- Устанавливаем параметр сессии, используемый в RLS-политиках
    PERFORM set_config('app.courier_name', courier_login, false);
    RETURN 'Контекст курьера установлен: ' || courier_login;
END;
$$;

-- Привилегия на выполнение функции только для role_app
REVOKE ALL ON FUNCTION set_courier_context(TEXT) FROM PUBLIC;
GRANT EXECUTE ON FUNCTION set_courier_context(TEXT) TO role_app;

COMMENT ON FUNCTION set_courier_context(TEXT) IS 'Устанавливает контекст сессии для RLS-политик курьера. Вызывается после аутентификации курьера в приложении.';
