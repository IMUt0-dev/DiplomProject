-- 8 - Позиции заказов - OrderItem
-- Каждый заказ содержит от 1 до 5 товаров
DO $$
DECLARE
    order_rec RECORD;
    product_count INTEGER;
    j INTEGER;
    selected_product_id INTEGER;
    selected_quantity INTEGER;
    selected_price NUMERIC(10,2);
BEGIN
    FOR order_rec IN SELECT order_id FROM orders LOOP
        product_count := FLOOR(RANDOM() * 5 + 1)::INTEGER;
        FOR j IN 1..product_count LOOP
            selected_product_id := FLOOR(RANDOM() * 1000 + 1)::INTEGER;
            selected_quantity := FLOOR(RANDOM() * 3 + 1)::INTEGER;
            SELECT price INTO selected_price
            FROM product
            WHERE product_id = selected_product_id;

            INSERT INTO orderitem (order_id, product_id, quantity, price_at_purchase)
            VALUES (order_rec.order_id, selected_product_id, selected_quantity, selected_price)
            ON CONFLICT (order_id, product_id) DO NOTHING;
        END LOOP;

        UPDATE orders o
        SET total_amount = (
            SELECT COALESCE(SUM(oi.quantity * oi.price_at_purchase), 0)
            FROM orderitem oi
            WHERE oi.order_id = o.order_id
        )
        WHERE o.order_id = order_rec.order_id;
    END LOOP;
END $$;

