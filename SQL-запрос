-- Представление v_product_catalog
CREATE VIEW v_product_catalog AS
SELECT
    p.product_id,
    p.article_number,
    p.name AS product_name,
    p.price,
    p.specifications->>'processor' AS processor,
    p.specifications->>'ram' AS ram,
    c.name AS category_name,
    m.name AS manufacturer_name
FROM product p
JOIN category c ON p.category_id = c.category_id
JOIN manufacturer m ON p.manufacturer_id = m.manufacturer_id
WHERE p.is_available = TRUE;

COMMENT ON VIEW v_product_catalog IS 'Полное представление товара для витрины.';

-- Представление v_customer_orders
CREATE OR REPLACE VIEW v_customer_orders AS
SELECT
    o.customer_id,
    c.email,
    c.first_name || ' ' || c.last_name AS customer_name,
    o.order_id,
    o.order_date,
    o.status AS order_status,
    o.total_amount,
    COUNT(oi.product_id) AS items_count,
    STRING_AGG(p.name, ', ' ORDER BY p.name) AS product_list,
    STRING_AGG(
        p.name || ' ×' || oi.quantity::TEXT || ' (' || oi.price_at_purchase::TEXT || ' ₽)',
        '; '
        ORDER BY p.name
    ) AS order_details,
    d.tracking_number,
    d.status AS delivery_status,
    d.estimated_delivery_date
FROM
    orders o
    JOIN customer c ON o.customer_id = c.customer_id
    JOIN orderitem oi ON o.order_id = oi.order_id
    JOIN product p ON oi.product_id = p.product_id
    LEFT JOIN delivery d ON o.order_id = d.order_id
GROUP BY
    o.customer_id, c.email, c.first_name, c.last_name,
    o.order_id, o.order_date, o.status, o.total_amount,
    d.tracking_number, d.status, d.estimated_delivery_date
ORDER BY
    o.order_date DESC;

COMMENT ON VIEW v_customer_orders IS 'История заказов клиента с детализацией состава. Для отображения в личном кабинете покупателя.';

-- Представление v_low_stock
CREATE OR REPLACE VIEW v_low_stock AS
SELECT
    p.product_id,
    p.name AS product_name,
    p.article_number,
    m.name AS manufacturer_name,
    c.name AS category_name,
    SUM(s.quantity_on_hand) AS total_stock,
    COUNT(s.warehouse_id) AS warehouse_count,
    p.price,
    CASE
        WHEN SUM(s.quantity_on_hand) = 0 THEN 'Нет в наличии'
        WHEN SUM(s.quantity_on_hand) < 5 THEN 'Критический остаток'
        WHEN SUM(s.quantity_on_hand) < 10 THEN 'Низкий остаток'
        ELSE 'В норме'
    END AS stock_status
FROM
    product p
    JOIN manufacturer m ON p.manufacturer_id = m.manufacturer_id
    JOIN category c ON p.category_id = c.category_id
    LEFT JOIN stock s ON p.product_id = s.product_id
WHERE
    p.is_available = TRUE
GROUP BY
    p.product_id, p.name, p.article_number, m.name, c.name, p.price
HAVING
    COALESCE(SUM(s.quantity_on_hand),0) < 5
ORDER BY
    total_stock ASC, p.name ASC;

COMMENT ON VIEW v_low_stock IS 'Товары с суммарным остатком менее 5 единиц. Для отдела закупок. Используется в аналитической отчётности.';

-- Представление v_order_summary
CREATE VIEW v_order_summary AS
SELECT
    o.order_id,
    o.order_date,
    o.status,
    o.total_amount,
    c.email,
    c.first_name || ' ' || c.last_name AS customer_name,
    d.tracking_number,
    d.status AS delivery_status
FROM orders o
JOIN customer c ON o.customer_id = c.customer_id
LEFT JOIN delivery d ON o.order_id = d.order_id;

-- Представление v_top_selling_products
CREATE OR REPLACE VIEW v_top_selling_products AS
SELECT
    p.product_id,
    p.name AS product_name,
    p.article_number,
    m.name AS manufacturer_name,
    cat.name AS category_name,
    p.price AS current_price,
    COUNT(DISTINCT oi.order_id) AS total_orders,
    SUM(oi.quantity) AS total_units_sold,
    SUM(oi.quantity * oi.price_at_purchase) AS total_revenue,
    ROUND(AVG(oi.price_at_purchase), 2) AS avg_selling_price,
    -- Рейтинг по количеству проданных единиц
    RANK() OVER (ORDER BY SUM(oi.quantity) DESC) AS sales_rank,
    -- Дата последней продажи
    MAX(o.order_date) AS last_sold_date
FROM
    product p
    JOIN manufacturer m ON p.manufacturer_id = m.manufacturer_id
    JOIN category cat ON p.category_id = cat.category_id
    LEFT JOIN orderitem oi ON p.product_id = oi.product_id
    LEFT JOIN orders o ON oi.order_id = o.order_id
        AND o.status NOT IN ('cancelled')  -- исключаем отменённые заказы
WHERE
    p.is_available = TRUE
GROUP BY
    p.product_id, p.name, p.article_number,
    m.name, cat.name, p.price
ORDER BY
    total_units_sold DESC NULLS LAST;

COMMENT ON VIEW v_top_selling_products IS 'Рейтинг товаров по объёму продаж. Используется для анализа спроса, формирования акций и рекомендаций.';

-- Представление v_daily_revenue
CREATE OR REPLACE VIEW v_daily_revenue AS
SELECT
    o.order_date::DATE AS sale_date,
    EXTRACT(YEAR FROM o.order_date) AS sale_year,
    EXTRACT(MONTH FROM o.order_date) AS sale_month,
    EXTRACT(DOW FROM o.order_date) AS sale_day_of_week,
    COUNT(DISTINCT o.order_id) AS total_orders,
    COUNT(DISTINCT o.customer_id) AS unique_customers,
    SUM(o.total_amount) AS daily_revenue,
    ROUND(AVG(o.total_amount), 2) AS avg_order_value,
    SUM(p.amount) AS total_paid,
    SUM(CASE WHEN p.status = 'completed' THEN p.amount ELSE 0 END) AS completed_payments,
    SUM(CASE WHEN p.status = 'refunded' THEN p.amount ELSE 0 END) AS refunded_amount
FROM
    orders o
    LEFT JOIN payment p ON o.order_id = p.order_id
WHERE
    o.status != 'cancelled'
GROUP BY
    o.order_date::DATE,
    EXTRACT(YEAR FROM o.order_date),
    EXTRACT(MONTH FROM o.order_date),
    EXTRACT(DOW FROM o.order_date)
ORDER BY
    sale_date DESC;

COMMENT ON VIEW v_daily_revenue IS 'Ежедневная финансовая отчётность: выручка, количество заказов, средний чек. Для финансового отдела и BI-аналитики.';

