-- Таблица category - Категория
CREATE TABLE category (
    category_id   INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    name          VARCHAR(100) NOT NULL,
    description   TEXT,
    parent_id     INTEGER,
    CONSTRAINT fk_category_parent
        FOREIGN KEY (parent_id)
        REFERENCES category(category_id)
        ON DELETE SET NULL
);

-- Индексы для category
CREATE INDEX idx_category_parent ON category(parent_id);

COMMENT ON TABLE category IS 'Иерархические категории товаров. Используется модель Adjacency List.';
COMMENT ON COLUMN category.category_id IS 'Автогенерируемый первичный ключ.';
COMMENT ON COLUMN category.parent_id IS 'Ссылка на родительскую категорию для построения иерархии.';

-- Таблица manufacturer - Производитель
CREATE TABLE manufacturer (
    manufacturer_id INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    name            VARCHAR(100) NOT NULL,
    country         VARCHAR(50),
    contact_info    TEXT
);

-- Индексы для manufacturer
CREATE UNIQUE INDEX idx_manufacturer_name ON manufacturer(name);

COMMENT ON TABLE manufacturer IS 'Производители электроники. Выделение в отдельную таблицу устраняет транзитивные зависимости.';
COMMENT ON COLUMN manufacturer.manufacturer_id IS 'Автогенерируемый первичный ключ.';

-- Таблица product - Товар
CREATE TABLE product (
    product_id      INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    article_number  VARCHAR(30) UNIQUE NOT NULL,
    name            VARCHAR(255) NOT NULL,
    description     TEXT,
    price           NUMERIC(10, 2) NOT NULL CHECK (price >= 0),
    is_available    BOOLEAN DEFAULT TRUE,
    category_id     INTEGER NOT NULL,
    manufacturer_id INTEGER NOT NULL,
    specifications  JSONB,
    CONSTRAINT fk_product_category
        FOREIGN KEY (category_id)
        REFERENCES category(category_id)
        ON DELETE RESTRICT,
    CONSTRAINT fk_product_manufacturer
        FOREIGN KEY (manufacturer_id)
        REFERENCES manufacturer(manufacturer_id)
        ON DELETE RESTRICT
);

-- Индексы для product
CREATE INDEX idx_product_category ON product(category_id);
CREATE INDEX idx_product_manufacturer ON product(manufacturer_id);
CREATE INDEX idx_product_price ON product(price);
CREATE INDEX idx_product_specifications ON product USING GIN (specifications);
CREATE INDEX idx_product_name ON product USING BTREE (name);

COMMENT ON TABLE product IS 'Основной каталог товаров. Гибридный подход: фиксированные поля + JSONB для динамических атрибутов.';
COMMENT ON COLUMN product.specifications IS 'Динамические технические характеристики в JSONB: процессор, память, экран и т.д.';
COMMENT ON COLUMN product.product_id IS 'Автогенерируемый первичный ключ.';
COMMENT ON COLUMN product.price IS 'Цена в рублях с точностью до копеек. Тип NUMERIC(10,2) исключает ошибки округления.';

-- Таблица customer - Покупатель
CREATE TABLE customer (
    customer_id     INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    email           VARCHAR(150) UNIQUE NOT NULL,
    password_hash   VARCHAR(255) NOT NULL,
    first_name      VARCHAR(50) NOT NULL,
    last_name       VARCHAR(50) NOT NULL,
    phone           VARCHAR(20),
    registration_date TIMESTAMPTZ DEFAULT NOW()
);

-- Индексы для customer
CREATE UNIQUE INDEX idx_customer_email ON customer(email);
CREATE INDEX idx_customer_registration ON customer(registration_date);

COMMENT ON TABLE customer IS 'Зарегистрированные покупатели. Пароли хранятся в виде хэша. Доступ к полю password_hash ограничен через GRANT и RLS.';
COMMENT ON COLUMN customer.customer_id IS 'Автогенерируемый первичный ключ.';

-- Таблица order - Заказ
CREATE TABLE orders (
    order_id        INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    order_date      TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    status          VARCHAR(20) NOT NULL DEFAULT 'pending'
                    CHECK (status IN ('pending', 'paid', 'shipped', 'delivered', 'cancelled')),
    total_amount    NUMERIC(10, 2) NOT NULL CHECK (total_amount >= 0),
    customer_id     INTEGER NOT NULL,
    delivery_address TEXT,
    CONSTRAINT fk_order_customer
        FOREIGN KEY (customer_id)
        REFERENCES customer(customer_id)
        ON DELETE RESTRICT
);

-- Индексы для order
CREATE INDEX idx_order_customer ON orders(customer_id);
CREATE INDEX idx_order_date ON orders(order_date);
CREATE INDEX idx_order_status ON orders(status);

COMMENT ON TABLE orders IS 'Заказы клиентов. Статусы отражают полный жизненный цикл заказа.';
COMMENT ON COLUMN orders.order_id IS 'Автогенерируемый первичный ключ.';

-- Таблица orderitem - Позиция заказа
CREATE TABLE orderitem (
    order_id        INTEGER NOT NULL,
    product_id      INTEGER NOT NULL,
    quantity        INTEGER NOT NULL CHECK (quantity > 0),
    price_at_purchase NUMERIC(10, 2) NOT NULL CHECK (price_at_purchase >= 0),
    CONSTRAINT pk_orderitem
        PRIMARY KEY (order_id, product_id),
    CONSTRAINT fk_orderitem_order
        FOREIGN KEY (order_id)
        REFERENCES orders(order_id)
        ON DELETE CASCADE,
    CONSTRAINT fk_orderitem_product
        FOREIGN KEY (product_id)
        REFERENCES product(product_id)
        ON DELETE RESTRICT
);

-- Индексы для orderitem
CREATE INDEX idx_orderitem_order ON orderitem(order_id);
CREATE INDEX idx_orderitem_product ON orderitem(product_id);

COMMENT ON TABLE orderitem IS 'Позиции заказа. Составной первичный ключ (order_id, product_id).';
COMMENT ON COLUMN orderitem.price_at_purchase IS 'Цена на момент покупки. Фиксирует коммерческие условия сделки.';

-- Таблица warehouse - Склад
CREATE TABLE warehouse (
    warehouse_id INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    name         VARCHAR(100) NOT NULL,
    address      TEXT
);

-- Индексы для warehouse
CREATE UNIQUE INDEX idx_warehouse_name ON warehouse(name);

COMMENT ON TABLE warehouse IS 'Склады интернет-магазина.';
COMMENT ON COLUMN warehouse.warehouse_id IS 'Автогенерируемый первичный ключ.';

-- Таблица stock - Остаток на складе
CREATE TABLE stock (
    product_id      INTEGER NOT NULL,
    warehouse_id    INTEGER NOT NULL,
    quantity_on_hand INTEGER NOT NULL DEFAULT 0 CHECK (quantity_on_hand >= 0),
    CONSTRAINT pk_stock
        PRIMARY KEY (product_id, warehouse_id),
    CONSTRAINT fk_stock_product
        FOREIGN KEY (product_id)
        REFERENCES product(product_id)
        ON DELETE CASCADE,
    CONSTRAINT fk_stock_warehouse
        FOREIGN KEY (warehouse_id)
        REFERENCES warehouse(warehouse_id)
        ON DELETE RESTRICT
);

-- Индексы для stock
CREATE INDEX idx_stock_warehouse ON stock(warehouse_id);
CREATE INDEX idx_stock_quantity ON stock(quantity_on_hand);

COMMENT ON TABLE stock IS 'Остатки товаров на складах. Составной ключ.';
COMMENT ON COLUMN stock.quantity_on_hand IS 'Текущее количество товара на складе (>= 0).';

-- Таблица payment - Платёж
CREATE TABLE payment (
    payment_id      INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    order_id        INTEGER NOT NULL,
    amount          NUMERIC(10, 2) NOT NULL CHECK (amount >= 0),
    payment_method  VARCHAR(30) NOT NULL,
    status          VARCHAR(20) NOT NULL DEFAULT 'pending'
                    CHECK (status IN ('pending', 'completed', 'failed', 'refunded')),
    transaction_date TIMESTAMPTZ DEFAULT NOW(),
    CONSTRAINT fk_payment_order
        FOREIGN KEY (order_id)
        REFERENCES orders(order_id)
        ON DELETE RESTRICT
);

-- Индексы для payment
CREATE INDEX idx_payment_order ON payment(order_id);
CREATE INDEX idx_payment_status ON payment(status);

COMMENT ON TABLE payment IS 'Платежи по заказам. Хранение информации о транзакциях для финансового учёта.';
COMMENT ON COLUMN payment.payment_id IS 'Автогенерируемый первичный ключ.';

-- Таблица delivery  - Доставка
CREATE TABLE delivery (
    delivery_id             INTEGER GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    order_id                INTEGER UNIQUE NOT NULL,
    tracking_number         VARCHAR(50),
    courier_name            VARCHAR(100),
    estimated_delivery_date DATE,
    actual_delivery_date    DATE,
    status                  VARCHAR(20) DEFAULT 'pending'
                            CHECK (status IN ('pending', 'in_transit', 'delivered', 'failed')),
    CONSTRAINT fk_delivery_order
        FOREIGN KEY (order_id)
        REFERENCES orders(order_id)
        ON DELETE CASCADE
);

-- Индексы для delivery
CREATE INDEX idx_delivery_status ON delivery(status);
CREATE INDEX idx_delivery_courier ON delivery(courier_name);

COMMENT ON TABLE delivery IS 'Данные о доставке заказов. Связь 1:1 с таблицей Order через уникальный внешний ключ.';
COMMENT ON COLUMN delivery.delivery_id IS 'Автогенерируемый первичный ключ.';
COMMENT ON COLUMN delivery.order_id IS 'Уникальный внешний ключ, обеспечивающий связь 1:1 с таблицей Order.';

